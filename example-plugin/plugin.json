{
  "name": "example-lsp-plugin",
  "version": "1.0.0",
  "description": "Example LSP plugin demonstrating environment variable usage",
  "author": "Claude Code",
  "license": "MIT",
  
  "userConfig": {
    "serverPort": {
      "type": "number",
      "title": "Server Port",
      "description": "The port number for the LSP server",
      "default": 8080,
      "minimum": 1024,
      "maximum": 65535
    },
    "apiKey": {
      "type": "string",
      "title": "API Key",
      "description": "Your API key for authentication (stored securely)",
      "sensitive": true
    },
    "logLevel": {
      "type": "string",
      "title": "Log Level",
      "description": "Logging verbosity",
      "enum": ["debug", "info", "warn", "error"],
      "default": "info"
    },
    "enableDebug": {
      "type": "boolean",
      "title": "Enable Debug Mode",
      "description": "Enable additional debug logging",
      "default": false
    }
  },
  
  "lspServers": {
    "example-language-server": {
      "command": "node",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/server.js",
        "--port", "${user_config.serverPort}",
        "--log-level", "${user_config.logLevel}",
        "--debug", "${user_config.enableDebug}"
      ],
      "env": {
        "API_KEY": "${user_config.apiKey}",
        "PLUGIN_ROOT": "${CLAUDE_PLUGIN_ROOT}",
        "DATA_DIR": "${CLAUDE_PLUGIN_DATA}",
        "CACHE_PATH": "${CLAUDE_PLUGIN_DATA}/cache",
        "LOG_FILE": "${CLAUDE_PLUGIN_DATA}/logs/server.log",
        "NODE_ENV": "${NODE_ENV:-production}",
        "CUSTOM_PATH": "${CUSTOM_BIN_PATH:-/usr/local/bin}"
      },
      "extensionToLanguage": {
        ".example": "example-lang",
        ".ex": "example-lang"
      },
      "workspaceFolder": "${user_config.workspaceRoot:-${HOME}/projects}"
    },
    
    "minimal-example": {
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/minimal-server",
      "args": ["--stdio"],
      "extensionToLanguage": {
        ".min": "minimal-lang"
      }
    },
    
    "env-var-demo": {
      "command": "env-demo-server",
      "args": [
        "--config", "${CLAUDE_PLUGIN_DATA}/config.json",
        "--home", "${HOME}",
        "--path", "${PATH}",
        "--custom", "${MY_CUSTOM_VAR:-default-value}"
      ],
      "env": {
        "DEMO_MODE": "true",
        "PLUGIN_PATH": "${CLAUDE_PLUGIN_ROOT}",
        "RESOLVED_HOME": "${HOME}"
      },
      "extensionToLanguage": {
        ".demo": "demo-lang"
      }
    }
  }
}
